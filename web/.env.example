# OpenPathshala prototype — environment configuration
# Copy to .env for local dev:  cp .env.example .env   (then fill in your key)
# NEVER commit a real key. .env is gitignored.

# --- LLM provider (OpenAI-compatible chat-completions) ----------------------
# Default provider is Groq. To run fully offline, point these at a local
# Ollama/vLLM server (the T0/T1 "open floor" story from README §7).
GROQ_API_KEY=your_groq_api_key_here
# LLM_API_KEY=                       # alternative to GROQ_API_KEY
# LLM_BASE_URL=https://api.groq.com/openai/v1

# --- model tiers (override to swap models without code changes) --------------
# LLM_MODEL_CHEAP=llama-3.1-8b-instant
# LLM_MODEL_REASONING=llama-3.3-70b-versatile
# LLM_MODEL_HARD=openai/gpt-oss-120b

# --- server -----------------------------------------------------------------
PORT=8080
RATE_LIMIT_PER_MIN=12
